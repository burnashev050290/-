import random

def guess_the_number():
    """Игра 'Угадай число'"""
    
    print("=" * 40)
    print("   Добро пожаловать в игру 'Угадай число'!")
    print("=" * 40)
    print("Я загадал число от 1 до 100.")
    print("У вас есть 10 попыток, чтобы его угадать.")
    print("-" * 40)
    
    # Генерируем случайное число от 1 до 100
    secret_number = random.randint(1, 100)
    max_attempts = 10
    attempts = 0
    
    while attempts < max_attempts:
        try:
            # Запрашиваем предположение пользователя
            guess = int(input(f"\nПопытка {attempts + 1}/{max_attempts}. Ваше предположение: "))
            
            # Проверка диапазона
            if guess < 1 or guess > 100:
                print("Пожалуйста, введите число от 1 до 100!")
                continue
            
            attempts += 1
            
            # Проверка правильности
            if guess == secret_number:
                print(f"\n🎉 Поздравляю! Вы угадали число {secret_number} за {attempts} попыток!")
                print("🏆 Вы победили!")
                return
            elif guess < secret_number:
                print("📈 Слишком маленькое число! Попробуйте больше.")
            else:
                print("📉 Слишком большое число! Попробуйте меньше.")
                
        except ValueError:
            print("❌ Ошибка! Пожалуйста, введите целое число.")
    
    # Если попытки закончились
    print(f"\n💔 Игра окончена! Вы использовали все {max_attempts} попыток.")
    print(f"🔢 Загаданное число было: {secret_number}")
    print("👋 Попробуйте снова!")

def main():
    """Основная функция программы"""
    while True:
        guess_the_number()
        
        # Предложение сыграть снова
        play_again = input("\nХотите сыграть ещё раз? (да/нет): ").lower()
        if play_again not in ['да', 'yes', 'д', 'y']:
            print("\nСпасибо за игру! До встречи!")
            break
        print("\n" * 2)

if __name__ == "__main__":
    main()
